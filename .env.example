# Переменные окружения для xcell-proc
# Скопируйте в .env и заполните своими данными: cp .env.example .env
#
# Все переменные ниже переопределяют соответствующие значения из config.json.
# Можно использовать ТОЛЬКО .env (без config.json для SMTP-части),
# или комбинировать: базовые настройки в config.json, секреты в .env.

# SMTP настройки
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM_EMAIL=your-email@gmail.com
SMTP_FROM_NAME=Your Name

# Пути (переопределяют paths в config.json)
EXCEL_FOLDER=data
ATTACHMENTS_FOLDER=attachments
TEMPLATES_FOLDER=templates
